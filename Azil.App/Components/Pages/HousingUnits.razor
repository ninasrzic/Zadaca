
@page "/housingunits"
@using AzilEdu.Shared.DTOs
@using System.Net.Http.Json
@inject HttpClient Http

<MudText Typo="Typo.h4" GutterBottom="true">Smještajne jedinice</MudText>

<MudText Typo="Typo.body1" Class="mb-4">
    Ovo je prikaz i filtriranje bokseva, soba i drugih životinjskih prostorija.
</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/housingunits/create" Class="mb-4">
    Nova jedinica
</MudButton>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle2">Ukupan broj jedinica</MudText>
            <MudText Typo="Typo.h5">@TotalUnits</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle2">Broj aktivnih jedinica</MudText>
            <MudText Typo="Typo.h5">@ActiveUnits</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle2">Broj punih jedinica</MudText>
            <MudText Typo="Typo.h5">@FullUnits</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle2">Ukupan slobodni kapacitet</MudText>
            <MudText Typo="Typo.h5">@FreeCapacity</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined" Class="mb-4">
    <MudButton OnClick="@ShowAllUnits">Sve</MudButton>
    <MudButton OnClick="@ShowActiveUnits">Samo aktivne</MudButton>
    <MudButton OnClick="@ShowFullUnits">Samo pune</MudButton>
    <MudButton OnClick="@ShowFreeUnits">Samo slobodne</MudButton>
</MudButtonGroup>

<MudTable Items="@FilteredHousingUnits" Hover="true" Striped="true" Bordered="true" Dense="true">
    <HeaderContent>
        <MudTh>Slika</MudTh>
        <MudTh>Naziv</MudTh>
        <MudTh>Tip</MudTh>
        <MudTh>Kapacitet</MudTh>
        <MudTh>Zauzeto</MudTh>
        <MudTh>Slobodno</MudTh>
        <MudTh>Zadnje čišćenje</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Akcije</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Slika">
            <MudAvatar Size="Size.Large">
                <MudImage Src="@context.ImageUrl" Alt="@context.Name" />
            </MudAvatar>
        </MudTd>
        <MudTd DataLabel="Ime">@context.Name</MudTd>
        <MudTd DataLabel="Vrsta unita">@context.UnitType</MudTd>
        <MudTd DataLabel="Kapacitet">@context.Capacity</MudTd>
        <MudTd DataLabel="Zauzetost">@context.Occupied</MudTd>
        <MudTd DataLabel="Aktivno">@GetActivity(context)</MudTd>
        <MudTd DataLabel="Zadnje ocisceno">@GetCleaningDateText(context)</MudTd>

        <MudTd DataLabel="Status">
            <MudChip T="string"
                     Color="@GetUnitStatusColor(context)"
                     Variant="Variant.Filled">
                @GetUnitStatusText(context)
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Akcije">
            <MudButton Variant="Variant.Text" Color="Color.Primary" Href="@($"/housingunits/edit/{context.Id}")">
                Uredi
            </MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@(() => DeleteHousingUnit(context.Id))">
                Obriši
            </MudButton>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private List<HousingUnitDto> housingUnits = new();

    private int TotalUnits => housingUnits.Count;
    private int ActiveUnits => housingUnits.Count(u => u.IsActive);
    private int FullUnits => housingUnits.Count(u => u.Occupied >= u.Capacity);
    private int FreeCapacity => housingUnits.Sum(u => GetFreeCapacity(u));

    private string selectedHousingFilter = "Sve";

    protected override async Task OnInitializedAsync()
    {
        List<HousingUnitDto>? result = await Http.GetFromJsonAsync<List<HousingUnitDto>>("api/housingunits");
        housingUnits = result ?? new List<HousingUnitDto>();
    }

    private IEnumerable<HousingUnitDto> FilteredHousingUnits =>
    selectedHousingFilter switch
    {
        "Aktivne" => housingUnits.Where(unit => unit.IsActive),
        "Pune" => housingUnits.Where(unit => GetFreeCapacity(unit) == 0),
        "Slobodno" => housingUnits.Where(unit => unit.IsActive && GetFreeCapacity(unit) > 0),
        _ => housingUnits
    };

    private async Task DeleteHousingUnit(int id)
    {
        var response = await Http.DeleteAsync($"api/housingunits/{id}");

        if (response.IsSuccessStatusCode)
        {
            housingUnits = housingUnits.Where(a => a.Id != id).ToList();
        }
    }

    private void ShowAllUnits()
    {
        selectedHousingFilter = "Sve";
    }

    private void ShowActiveUnits()
    {
        selectedHousingFilter = "Aktivne";
    }

    private void ShowFullUnits()
    {
        selectedHousingFilter = "Pune";
    }

    private void ShowFreeUnits()
    {
        selectedHousingFilter = "Slobodno";
    }

    private int GetFreeCapacity(HousingUnitDto unit)
    {
        return unit.Capacity - unit.Occupied;
    }

    private string GetCleaningDateText(HousingUnitDto unit)
    {
        if (unit.LastCleanedAt.HasValue)
        {
            return unit.LastCleanedAt.Value.ToShortDateString();
        }

        return "Nije uneseno";
    }

    private string GetActivity(HousingUnitDto unit)
    {
        if (unit.IsActive)
        {
            return "Da";
        }
        else
        {
            return "Ne";
        }
    }

    private string GetUnitStatusText(HousingUnitDto unit)
    {
        if (!unit.IsActive)
        {
            return "Neaktivno";
        }

        if (unit.Occupied >= unit.Capacity)
        {
            return "Puno";
        }

        return "Slobodno";
    }

    private Color GetUnitStatusColor(HousingUnitDto unit)
    {
        if (!unit.IsActive)
        {
            return Color.Default;
        }

        if (unit.Occupied >= unit.Capacity)
        {
            return Color.Error;
        }

        return Color.Success;
    }
}
